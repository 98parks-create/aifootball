# TAD AI 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 값을 채우세요
# cp .env.example .env

# ── 서버 보안 키 (랜덤 문자열로 변경) ──────────────────────────────────────────
SECRET_KEY=your-random-secret-key-here

# ── 이메일 발송 (Gmail SMTP) ──────────────────────────────────────────────────
# Gmail 계정 주소
MAIL_USER=your-email@gmail.com

# Gmail 앱 비밀번호 (일반 비밀번호 아님 — 아래 발급 방법 참고)
MAIL_PASS=xxxx-xxxx-xxxx-xxxx

# 발신자 표시 이름 (비워두면 MAIL_USER 사용)
MAIL_FROM=your-email@gmail.com

# ── 서비스 도메인 (이메일 결과 링크에 사용) ──────────────────────────────────
# 로컬 개발 시
BASE_URL=http://localhost:5000
# 실제 배포 시 (예시)
# BASE_URL=https://tad-ai.com
